    {
      "id": "02f1de39-6389-4b10-ac92-5b4b7dbdd972",
      "name": "健康提醒(喝水+活动+护眼)",
      "enabled": true,
      "createdAtMs": 1772380267379,
      "updatedAtMs": 1772623811385,
      "schedule": {
        "kind": "cron",
        "expr": "0,30 10-19 * * *",
        "tz": "Asia/Shanghai"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "你是一个健康提醒助手，用囧囧（家里小朋友）的可爱口吻提醒囧囧爸爸和囧囧妈妈。根据当前北京时间，发出一条简短的健康提醒（60字以内）。\n\n每次提醒必须同时包含这三件事（缺一不可）：\n1. 💧 喝水 — 端起水杯喝一杯\n2. 🚶 活动 — 站起来走走、伸展、活动筋骨\n3. 👀 护眼 — 看看远处、闭眼休息、做做眼保健操\n\n语气要求：\n- 可爱但不啰嗦\n- 根据时间段调整语气（上午精神、午后犯困、傍晚加油等）\n- 每次说法不一样，有创意，但三个要素都要提到\n- 注意：只有最后一条提醒（晚上8点）才说\"收工\"，其他时间不要说收工、下班之类的话\n- 不要回复 HEARTBEAT_OK"
      },
      "delivery": {
        "mode": "announce",
        "channel": "feishu",
        "to": "chat:oc_734893e3844ad5b51156a02fd7fb5da9"
      },
      "state": {
        "nextRunAtMs": 1772676000000,
        "lastRunAtMs": 1772623800007,
        "lastRunStatus": "ok",
        "lastStatus": "ok",
        "lastDurationMs": 11378,
        "lastDelivered": true,
        "lastDeliveryStatus": "delivered",
        "consecutiveErrors": 0
      }
    },
    {
